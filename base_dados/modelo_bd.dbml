Table mensagens_contacto {
  id int [pk, increment]
  nome varchar
  email varchar
  mensagem text
  data_envio datetime
}

Table conteudos_publicos {
  id int [pk, increment]
  nome_campo varchar [not null, unique]
  conteudo_campo text
}

Table localizacoes {
  id int [pk, increment]
  codigo varchar [not null, unique]
  edificio varchar
  piso varchar
  servico varchar
  sala varchar
  observacoes text
}

Table fornecedores {
  id int [pk, increment]
  codigo varchar [not null, unique]
  nome_empresa varchar [not null]
  nif varchar
  telefone varchar
  email varchar
  morada varchar
  website varchar
  pessoa_contacto varchar
  telefone_pessoa_contacto varchar
  tipo varchar
  observacoes text
}

Table documentacao_fornecedores {
  id int [pk, increment]
  fornecedor_id int [not null, ref: > fornecedores.id]
  tipo_documento varchar
  nome_documento varchar
  data_documento date
  validade_documento date
  ficheiro_documento varchar
}

Table equipamentos {
  id int [pk, increment]
  codigo varchar [not null, unique]
  designacao varchar [not null]
  categoria varchar
  marca varchar
  modelo varchar
  numero_serie varchar
  fabricante varchar
  ano_fabrico int
  estado varchar
  criticidade varchar
  observacoes text
  localizacao_id int [ref: > localizacoes.id]
  observacoes_localizacao text
}

Table documentacao_equipamentos {
  id int [pk, increment]
  equipamento_id int [not null, ref: > equipamentos.id]
  tipo_separador varchar
  tipo_documento varchar
  nome_documento varchar
  data_documento date
  validade_documento date
  ficheiro_documento varchar
}

Table acessorios {
  id int [pk, increment]
  equipamento_id int [not null, ref: > equipamentos.id]
  nome varchar
  referencia varchar
  quantidade int
  unidade varchar
  estado varchar
  observacoes text
}

Table consumiveis {
  id int [pk, increment]
  equipamento_id int [not null, ref: > equipamentos.id]
  nome varchar
  referencia varchar
  quantidade int
  unidade varchar
  estado varchar
  observacoes text
}

Table aquisicao_equipamentos {
  id int [pk, increment]
  equipamento_id int [not null, ref: > equipamentos.id]
  data_aquisicao date
  custo_aquisicao decimal(10,2)
  tipo_entrada varchar
  observacoes text
}

Table equipamento_fornecedor {
  equipamento_id int [not null, ref: > equipamentos.id]
  fornecedor_id int [not null, ref: > fornecedores.id]

  tipo_fornecedor varchar
  pessoa_contacto varchar
  telefone_pessoa_contacto varchar
  morada varchar
  observacoes text

  indexes {
    (equipamento_id, fornecedor_id) [pk]
  }
}

Table garantias_equipamentos {
  id int [pk, increment]
  equipamento_id int [not null, ref: > equipamentos.id]
  data_inicio date
  data_fim date
  observacoes text
}

Table contratos_manutencao {
  id int [pk, increment]
  equipamento_id int [not null, ref: > equipamentos.id]
  tem_contrato boolean
  tipo_contrato varchar
  entidade_responsavel varchar
  periodicidade varchar
  observacoes text
}

Table utilizadores {
  id int [pk, increment]
  nome varchar [not null]
  email varchar [not null, unique]
  password_hash varchar [not null]
  perfil varchar
  ativo boolean
  created_at datetime
}

Table historico_equipamentos {
  id int [pk, increment]
  equipamento_id int [not null, ref: > equipamentos.id]
  utilizador_id int [ref: > utilizadores.id]
  tipo_alteracao varchar
  descricao text
  data_alteracao datetime
}