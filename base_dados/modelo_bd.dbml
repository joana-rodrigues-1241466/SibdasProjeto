// ============================================================
// SISTEMA DE GESTÃO DE INVENTÁRIO HOSPITALAR
// Modelo da Base de Dados - DBML v3
// LEBIOM | SIBDAS 2025-2026
// ============================================================


// ============================================================
// TABELAS DE LOOKUP
// ============================================================

Table estados_equipamento {
  id         int     [pk, increment]
  designacao varchar [not null, unique]
  ordem      int     [not null, default: 0]
}

Table criticidades {
  id         int     [pk, increment]
  designacao varchar [not null, unique]
  ordem      int     [not null, default: 0]
}

Table categorias {
  id         int     [pk, increment]
  designacao varchar [not null, unique]
  ordem      int     [not null, default: 0]
}

Table tipos_fornecedor {
  id         int     [pk, increment]
  designacao varchar [not null, unique]
  ordem      int     [not null, default: 0]
}

Table tipos_entrada {
  id         int     [pk, increment]
  designacao varchar [not null, unique]
  ordem      int     [not null, default: 0]
}

Table separadores_documentacao {
  id         int     [pk, increment]
  designacao varchar [not null, unique]
  ordem      int     [not null, default: 0]
}

Table tipos_documento_equipamento {
  id           int     [pk, increment]
  separador_id int     [ref: > separadores_documentacao.id]
  designacao   varchar [not null, unique]
  ordem        int     [not null, default: 0]
}

Table tipos_documento_fornecedor {
  id         int     [pk, increment]
  designacao varchar [not null, unique]
  ordem      int     [not null, default: 0]
}

Table perfis_utilizador {
  id         int     [pk, increment]
  designacao varchar [not null, unique]
  ordem      int     [not null, default: 0]
}

Table tipos_contrato {
  id         int     [pk, increment]
  designacao varchar [not null, unique]
  ordem      int     [not null, default: 0]
}

Table periodicidades {
  id         int     [pk, increment]
  designacao varchar [not null, unique]
  ordem      int     [not null, default: 0]
}

Table unidades {
  id         int     [pk, increment]
  designacao varchar [not null, unique]
  ordem      int     [not null, default: 0]
}

Table estados_acessorio {
  id         int     [pk, increment]
  designacao varchar [not null, unique]
  valor      varchar [not null, unique]
  // valor interno usado no código (ex: 'em-uso')
  ordem      int     [not null, default: 0]
}


// ============================================================
// TABELAS PRINCIPAIS
// ============================================================

Table utilizadores {
  id              int      [pk, increment]
  nome            varchar  [not null]
  email           varchar  [not null, unique]
  password_hash   varchar  [not null]
  perfil_id       int      [not null, ref: > perfis_utilizador.id]
  ativo           boolean  [default: true]
  token_reset     varchar
  token_expira    datetime
  token_remember  varchar
  created_at      datetime [default: `CURRENT_TIMESTAMP`]
  updated_at      datetime [default: `CURRENT_TIMESTAMP`]
}

Table localizacoes {
  id          int      [pk, increment]
  codigo      varchar  [not null, unique]
  edificio    varchar
  piso        varchar
  servico     varchar
  sala        varchar
  observacoes text
  ativo       boolean  [default: true]
  created_at  datetime [default: `CURRENT_TIMESTAMP`]
  updated_at  datetime [default: `CURRENT_TIMESTAMP`]
}

Table fornecedores {
  id                       int      [pk, increment]
  codigo                   varchar  [not null, unique]
  nome_empresa             varchar  [not null]
  nif                      varchar
  telefone                 varchar
  email                    varchar
  distrito                 varchar
  pais                     varchar  [default: 'Portugal']
  website                  varchar
  pessoa_contacto          varchar
  telefone_pessoa_contacto varchar
  tipo_id                  int      [ref: > tipos_fornecedor.id]
  observacoes              text
  ativo                    boolean  [default: true]
  created_at               datetime [default: `CURRENT_TIMESTAMP`]
  updated_at               datetime [default: `CURRENT_TIMESTAMP`]
}

Table documentacao_fornecedores {
  id                     int     [pk, increment]
  fornecedor_id          int     [not null, ref: > fornecedores.id]
  tipo_documento_id      int     [ref: > tipos_documento_fornecedor.id]
  nome_documento         varchar
  data_documento         date
  validade_documento     date
  ficheiro_documento     varchar
  nome_original_ficheiro varchar
}

Table equipamentos {
  id                      int      [pk, increment]
  codigo                  varchar  [not null, unique]
  designacao              varchar  [not null]
  categoria_id            int      [ref: > categorias.id]
  marca                   varchar
  modelo                  varchar
  numero_serie            varchar
  fabricante              varchar
  ano_fabrico             int
  estado_id               int      [ref: > estados_equipamento.id]
  criticidade_id          int      [ref: > criticidades.id]
  observacoes             text
  localizacao_id          int      [ref: > localizacoes.id]
  observacoes_localizacao text
  ativo                   boolean  [default: true]
  created_at              datetime [default: `CURRENT_TIMESTAMP`]
  updated_at              datetime [default: `CURRENT_TIMESTAMP`]

  indexes {
    (numero_serie, fabricante, modelo) [unique]
  }
}

Table documentacao_equipamentos {
  id                     int     [pk, increment]
  equipamento_id         int     [not null, ref: > equipamentos.id]
  separador_id           int     [ref: > separadores_documentacao.id]
  tipo_documento_id      int     [ref: > tipos_documento_equipamento.id]
  nome_documento         varchar
  data_documento         date
  validade_documento     date
  ficheiro_documento     varchar
  nome_original_ficheiro varchar
}

Table acessorios {
  id             int     [pk, increment]
  equipamento_id int     [not null, ref: > equipamentos.id]
  nome           varchar
  referencia     varchar
  quantidade     int     [default: 1]
  unidade_id     int     [ref: > unidades.id]
  estado_id      int     [ref: > estados_acessorio.id]
  observacoes    text
}

Table consumiveis {
  id             int     [pk, increment]
  equipamento_id int     [not null, ref: > equipamentos.id]
  nome           varchar
  referencia     varchar
  quantidade     int     [default: 1]
  unidade_id     int     [ref: > unidades.id]
  estado_id      int     [ref: > estados_acessorio.id]
  observacoes    text
}

Table aquisicao_equipamentos {
  id              int          [pk, increment]
  equipamento_id  int          [not null, ref: > equipamentos.id]
  data_aquisicao  date
  custo_aquisicao decimal(10,2)
  moeda           varchar      [default: 'EUR']
  tipo_entrada_id int          [ref: > tipos_entrada.id]
  observacoes     text
  created_at      datetime     [default: `CURRENT_TIMESTAMP`]
  updated_at      datetime     [default: `CURRENT_TIMESTAMP`]
}

Table equipamento_fornecedor {
  equipamento_id           int     [not null, ref: > equipamentos.id]
  fornecedor_id            int     [not null, ref: > fornecedores.id]
  tipo_fornecedor_id       int     [ref: > tipos_fornecedor.id]
  pessoa_contacto          varchar
  telefone_pessoa_contacto varchar
  observacoes              text

  indexes {
    (equipamento_id, fornecedor_id) [pk]
  }
}

Table garantias_equipamentos {
  id             int  [pk, increment]
  equipamento_id int  [not null, ref: > equipamentos.id]
  data_inicio    date
  data_fim       date
  observacoes    text
}

Table contratos_manutencao {
  id                   int     [pk, increment]
  equipamento_id       int     [not null, ref: > equipamentos.id]
  tem_contrato         boolean [default: false]
  tipo_contrato_id     int     [ref: > tipos_contrato.id]
  entidade_responsavel varchar
  periodicidade_id     int     [ref: > periodicidades.id]
  observacoes          text
}

Table historico_equipamentos {
  id               int      [pk, increment]
  equipamento_id   int      [not null, ref: > equipamentos.id]
  utilizador_id    int      [ref: > utilizadores.id]
  tipo_alteracao   varchar
  descricao        text
  dados_anteriores json
  dados_novos      json
  data_alteracao   datetime [default: `CURRENT_TIMESTAMP`]
}

Table conteudos_publicos {
  id             int      [pk, increment]
  nome_campo     varchar  [not null, unique]
  conteudo_campo text
  updated_at     datetime [default: `CURRENT_TIMESTAMP`]
}

Table mensagens_contacto {
  id         int      [pk, increment]
  nome       varchar
  email      varchar
  mensagem   text
  data_envio datetime [default: `CURRENT_TIMESTAMP`]
  lido       boolean  [default: false]
  lido_em    datetime
  lido_por   int      [ref: > utilizadores.id]
}
